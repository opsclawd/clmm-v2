{
  "name": "@clmm/adapters",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "build:worker": "tsc -p tsconfig.json",
    "start:worker": "node dist/inbound/jobs/main.js",
    "lint": "eslint src --ext .ts",
    "dev:api": "tsx src/inbound/http/main.ts",
    "dev:worker": "tsx src/inbound/jobs/main.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clmm/application": "workspace:*",
    "@clmm/domain": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-fastify": "^10.0.0",
    "@orca-so/whirlpools": "^7.0.2",
    "@orca-so/whirlpools-client": "^6.2.1",
    "@solana-mobile/mobile-wallet-adapter-protocol": "^2.2.6",
    "@solana-mobile/mobile-wallet-adapter-protocol-kit": "^0.2.3",
    "@solana/kit": "^6.5.0",
    "drizzle-orm": "^0.36.0",
    "expo-notifications": "^55.0.13",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "postgres": "^3.4.0",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@clmm/config": "workspace:*",
    "@clmm/testing": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
