{
  "extends": "@clmm/config/tsconfig/base",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "paths": {
      "@clmm/domain": ["../domain/src/index.ts"],
      "@clmm/testing": ["../testing/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts"],
  "references": [{ "path": "../domain" }]
}
